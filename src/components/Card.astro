---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const baseStyles = 'bg-warm-white rounded-2xl p-6 shadow-sm border border-text-faint/10 hover:shadow-md hover:border-text-faint/20 transition-all duration-200';

const classes = [baseStyles, className].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
