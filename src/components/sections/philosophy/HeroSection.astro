<section class="relative min-h-[70vh] pt-32 pb-20 md:pt-40 md:pb-28 flex items-center overflow-hidden bg-warm-cream">
  <!-- Soft organic background shapes -->
  <div class="absolute top-0 right-0 w-[50%] h-full bg-storehouse-50/40 rounded-bl-[120px] -z-0"></div>
  <div class="absolute -top-32 -right-32 w-96 h-96 bg-storehouse-200/20 rounded-full blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-3xl">
      <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">
        Our philosophy
      </p>

      <h1 class="mt-6 font-display text-5xl sm:text-6xl lg:text-7xl text-text-deep leading-[0.95] reveal reveal-delay-1">
        Why giving<br />
        comes <span class="text-storehouse-600">first.</span>
      </h1>

      <p class="mt-8 text-lg sm:text-xl text-text-body leading-relaxed max-w-xl reveal reveal-delay-2">
        Storehouse isn't just a different budget app. It's a different way
        of thinking about money &mdash; rooted in generosity, margin,
        and trust.
      </p>

      <div class="mt-12 flex items-center gap-6 reveal reveal-delay-3">
        <div class="w-12 h-px bg-storehouse-400"></div>
        <p class="text-sm text-text-muted font-medium tracking-wide">
          A 5-minute read
        </p>
      </div>
    </div>
  </div>
</section>
