---
const meanings = [
  {
    label: 'Provision',
    description: 'A place to store provision for lean times',
    color: 'bg-storehouse-500',
  },
  {
    label: 'Generosity',
    description: 'A practice of putting generosity first',
    color: 'bg-giving',
  },
  {
    label: 'Trust',
    description: 'A foundation of trust rather than anxiety',
    color: 'bg-saving',
  },
];
---

<section class="py-24 md:py-36 bg-warm-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="max-w-4xl mx-auto">
      <!-- Scripture as centerpiece -->
      <div class="text-center reveal">
        <p class="font-quote text-3xl sm:text-4xl lg:text-5xl text-text-deep leading-[1.2] italic">
          "Bring the whole tithe into the storehouse, that there may be food in my house."
        </p>
        <p class="mt-6 text-sm text-text-muted tracking-wide uppercase font-semibold">
          Malachi 3:10
        </p>
      </div>

      <!-- Divider -->
      <div class="my-16 flex justify-center reveal">
        <div class="w-16 h-px bg-text-faint/30"></div>
      </div>

      <!-- Explanation -->
      <div class="grid md:grid-cols-12 gap-8 md:gap-12">
        <div class="md:col-span-5 reveal">
          <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase">
            The name
          </p>
          <h2 class="mt-4 font-display text-3xl sm:text-4xl text-text-deep leading-[1.05]">
            Why we chose this name.
          </h2>
        </div>

        <div class="md:col-span-6 md:col-start-7 space-y-6 text-lg text-text-body leading-relaxed reveal reveal-delay-1">
          <p>
            In ancient Israel, the storehouse was where the community stored provision &mdash; grain, oil, wine. It was a place of abundance, set aside for both regular needs and times of crisis.
          </p>
          <p>
            That's what we're helping you build:
          </p>
        </div>
      </div>

      <!-- Three meanings -->
      <div class="mt-16 grid md:grid-cols-3 gap-6 reveal reveal-delay-2">
        {meanings.map((item) => (
          <div class="p-8 bg-warm-white rounded-2xl">
            <div class={`w-2 h-2 rounded-full ${item.color} mb-4`}></div>
            <h3 class="font-display text-lg text-text-deep mb-2">
              {item.label}
            </h3>
            <p class="text-text-muted leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
