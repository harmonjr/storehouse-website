---
const clarifications = [
  'We are NOT saying God will make you rich if you give.',
  'We are NOT saying poverty is a lack of faith.',
  'We are NOT saying you should feel guilty about spending.',
  'We are NOT saying our way is the only way.',
];
---

<section class="py-24 md:py-36 bg-warm-stone grain-overlay">
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="max-w-2xl reveal">
      <p class="text-storehouse-400 font-semibold text-sm tracking-widest uppercase">
        An important note
      </p>
      <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-warm-white leading-[1.05]">
        What we're <em class="not-italic text-storehouse-400">not</em> saying.
      </h2>
    </div>

    <!-- Clarifications as editorial numbered list -->
    <div class="mt-16 grid gap-8 md:gap-0 md:divide-y md:divide-warm-white/10">
      {clarifications.map((item, i) => (
        <div class="md:grid md:grid-cols-12 md:gap-8 md:py-8 first:md:pt-0 last:md:pb-0 reveal">
          <div class="md:col-span-1">
            <span class="font-display text-2xl text-storehouse-500/60">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>
          <div class="md:col-span-10 mt-2 md:mt-0">
            <p class="text-lg text-warm-white/80 leading-relaxed">
              {item}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing -->
    <div class="mt-20 reveal">
      <div class="flex justify-center">
        <div class="w-16 h-px bg-warm-white/20"></div>
      </div>
      <p class="mt-10 font-quote text-2xl sm:text-3xl text-warm-white/80 text-center italic leading-snug max-w-2xl mx-auto">
        "A tool built on biblical conviction, offered with open hands."
      </p>
    </div>

  </div>
</section>
