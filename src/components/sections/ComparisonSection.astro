---
const comparisons = [
  { other: 'Giving is optional', storehouse: 'Giving comes first' },
  { other: 'Track every category', storehouse: 'Track one number' },
  { other: 'Built for steady paychecks', storehouse: 'Built for real life' },
  { other: 'Restriction mindset', storehouse: 'Freedom through clarity' },
  { other: 'You failed the budget', storehouse: 'The budget serves you' },
];
---

<section class="py-24 md:py-36 bg-warm-cream">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="max-w-2xl reveal">
      <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase">
        The difference
      </p>
      <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text-deep leading-[1.05]">
        This isn't another<br />budget app.
      </h2>
    </div>

    <div class="mt-16 max-w-4xl">
      <div class="overflow-hidden rounded-2xl border border-text-faint/15 shadow-xs bg-warm-white reveal reveal-delay-1">
        <table class="w-full">
          <thead>
            <tr class="bg-warm-gray-50">
              <th class="px-6 py-4 text-left text-sm font-semibold text-text-muted uppercase tracking-wider">
                Other Apps
              </th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-storehouse-600 uppercase tracking-wider">
                Storehouse
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-text-faint/10">
            {comparisons.map((row) => (
              <tr class="transition-colors duration-200 hover:bg-warm-gray-50/50 reveal">
                <td class="px-6 py-4 text-text-muted">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-text-faint flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    {row.other}
                  </span>
                </td>
                <td class="px-6 py-4 text-text-deep font-medium">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-storehouse-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {row.storehouse}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-12 text-lg text-text-muted max-w-xl reveal reveal-delay-2">
      We're not here to optimize every dollar. We're here to give you peace.
    </p>

  </div>
</section>
