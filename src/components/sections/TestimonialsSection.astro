---
const testimonials = [
  {
    quote: "For the first time, I actually know what I can spend without doing mental math or feeling guilty.",
    name: 'Stacy',
    role: 'freelance designer',
  },
  {
    quote: "We've tried every budget app. This is the first one that stuck — because it's actually simple.",
    name: 'Randy and Karen',
    role: 'married with 1 son',
  },
  {
    quote: "The Safe to Spend is a great feature. You should call it the 'eliminate arguments' feature.",
    name: 'Joe',
    role: 'married father of 2 boys',
  },
];
---

<section class="py-24 md:py-36 bg-warm-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="max-w-3xl reveal">
      <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase">
        Early voices
      </p>
      <h2 class="mt-4 font-display text-3xl sm:text-4xl text-text-deep leading-[1.05]">
        People are finding peace.
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-8 lg:gap-10">
      {testimonials.map((testimonial, index) => (
        <div
          class:list={[
            'relative rounded-2xl p-8 border border-storehouse-100/60 bg-warm-cream',
            'hover:shadow-sm transition-shadow duration-200',
            'reveal',
            index === 1 && 'reveal-delay-1',
            index === 2 && 'reveal-delay-2',
          ]}
        >
          <span
            class="block font-quote text-6xl text-storehouse-400/30 leading-none select-none"
            aria-hidden="true"
          >&ldquo;</span>
          <div class="flex flex-col h-full -mt-2">
            <p class="text-text-body flex-1 text-lg leading-relaxed">
              {testimonial.quote}
            </p>
            <div class="mt-8 pt-5 border-t border-storehouse-100/60">
              <p class="font-semibold text-text-deep">{testimonial.name}</p>
              <p class="text-sm text-text-muted mt-0.5">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
