---
const builtFor = [
  "Anyone who feels stretched \u2014 not because they don't earn enough, but because there's no margin",
  'Couples who want to see the same number and stop arguing about money',
  'People with irregular income who need a system that adapts',
  'Families who want to give generously but can\'t find the breathing room',
];

const notFor = [
  'People who want to track every dollar across dozens of categories',
  'Investment managers or day traders',
  "Anyone who needs real-time automatic bank sync (we use weekly file imports \u2014 your banking credentials stay in your hands)",
];
---

<section class="py-24 md:py-36 bg-warm-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="max-w-2xl reveal">
      <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase">
        Who it's for
      </p>
      <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text-deep leading-[1.05]">
        Built for real people<br />with real lives.
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl">

      <!-- Built For -->
      <div class="rounded-2xl bg-warm-white border border-text-faint/10 p-8 sm:p-10 shadow-xs transition-shadow duration-200 hover:shadow-sm reveal reveal-delay-1">
        <h3 class="font-display text-xl text-text-deep mb-8">
          Storehouse is built for...
        </h3>
        <ul class="space-y-5">
          {builtFor.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-storehouse-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-text-body leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Not For -->
      <div class="rounded-2xl bg-warm-white border border-text-faint/10 p-8 sm:p-10 shadow-xs transition-shadow duration-200 hover:shadow-sm reveal reveal-delay-2">
        <h3 class="font-display text-xl text-text-deep mb-8">
          Storehouse is not for...
        </h3>
        <ul class="space-y-5">
          {notFor.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-text-faint flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-text-muted leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
