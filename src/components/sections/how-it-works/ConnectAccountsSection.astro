---
const features = [
  "What's coming in \u2014 paychecks, deposits, transfers",
  "What's going out \u2014 purchases, bills, subscriptions",
  "What's sitting there \u2014 your actual balances",
];
---

<section class="py-24 md:py-36 bg-warm-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- Left: Explanation -->
      <div>
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">
          Step 2
        </p>
        <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text-deep leading-[1.05] reveal reveal-delay-1">
          Import your data.
        </h2>
        <p class="mt-6 text-lg text-text-body leading-relaxed reveal reveal-delay-2">
          Import transactions from your bank's CSV, OFX, or QFX export &mdash; or bring your YNAB data. Storehouse sees your complete picture:
        </p>

        <ul class="mt-8 space-y-4 reveal reveal-delay-3">
          {features.map((feature) => (
            <li class="flex items-start gap-3">
              <svg
                class="h-6 w-6 text-storehouse-500 flex-shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-text-body text-lg">{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: Security callout card -->
      <div class="reveal reveal-delay-2">
        <div class="rounded-2xl bg-warm-white border border-text-faint/10 p-8 sm:p-10 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.06)]">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-storehouse-50 border border-storehouse-200/60 flex items-center justify-center">
              <svg
                class="h-6 w-6 text-storehouse-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                />
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl text-text-deep">
                Your data stays in your hands.
              </h3>
              <p class="mt-3 text-text-body leading-relaxed">
                We never ask for your bank login &mdash; you export, you import, you control. One file from your bank, once a week. Two minutes.
              </p>
            </div>
          </div>

          <!-- Import format badges -->
          <div class="mt-8 flex flex-wrap gap-2">
            {['CSV', 'OFX', 'QFX', 'YNAB'].map((format) => (
              <span class="px-3 py-1.5 text-sm font-medium text-storehouse-700 bg-storehouse-50 rounded-lg border border-storehouse-200/40">
                {format}
              </span>
            ))}
          </div>
        </div>

        <!-- Callout box below -->
        <div class="mt-6 rounded-2xl bg-warm-white border border-text-faint/10 p-6 reveal reveal-delay-3">
          <p class="text-text-deep font-medium">
            Works with any bank that exports CSV.
          </p>
          <p class="mt-1 text-sm text-text-muted">
            No Plaid. No credentials. No third-party access.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
