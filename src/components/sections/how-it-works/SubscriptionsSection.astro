---
const trackingFeatures = [
  {
    number: '01',
    title: 'Active subscriptions',
    description: 'How many recurring charges you have',
  },
  {
    number: '02',
    title: 'Monthly cost',
    description: 'Your total recurring spend at a glance',
  },
  {
    number: '03',
    title: 'Annual cost',
    description: 'Often the real wake-up call',
  },
  {
    number: '04',
    title: 'Potential savings',
    description: 'If you cancel unused services',
  },
];
---

<section class="py-24 md:py-36 bg-warm-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Left: Big stat + context -->
      <div class="lg:col-span-5">
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">
          Subscription tracking
        </p>
        <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl text-text-deep leading-[1.05] reveal reveal-delay-1">
          Find the leaks.
        </h2>

        <!-- Big stat callout -->
        <div class="mt-8 reveal reveal-delay-2">
          <p class="font-display text-6xl sm:text-7xl text-storehouse-600 leading-none">
            $200+
          </p>
          <p class="mt-2 text-text-muted text-lg">
            per month &mdash; the average American's subscription spend
          </p>
          <p class="mt-1 text-sm text-text-faint">
            Most don't realize it.
          </p>
        </div>

        <p class="mt-8 text-lg text-text-body leading-relaxed reveal reveal-delay-3">
          Storehouse helps you track your recurring charges. Add your subscriptions and see the full picture.
        </p>
      </div>

      <!-- Right: Feature list as editorial grid -->
      <div class="lg:col-span-7">
        <div class="grid sm:grid-cols-2 gap-6 reveal reveal-delay-2">
          {trackingFeatures.map((feature) => (
            <div class="p-6 rounded-2xl bg-warm-white border border-text-faint/10 transition-shadow duration-200 hover:shadow-xs">
              <span class="font-display text-3xl text-storehouse-300">
                {feature.number}
              </span>
              <h3 class="mt-3 font-display text-lg text-text-deep">
                {feature.title}
              </h3>
              <p class="mt-1 text-sm text-text-muted">
                {feature.description}
              </p>
            </div>
          ))}
        </div>

        <!-- Closing callout -->
        <div class="mt-8 p-6 rounded-2xl bg-warm-white border border-text-faint/10 reveal reveal-delay-3">
          <p class="font-display text-xl text-text-deep">
            Small leaks sink big ships.
          </p>
          <p class="mt-1 text-text-muted">
            We help you spot them.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
