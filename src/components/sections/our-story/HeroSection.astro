---
---

<section class="relative min-h-[85vh] pt-28 pb-16 md:pt-36 md:pb-24 flex items-center overflow-hidden bg-warm-cream">
  <!-- Organic background shapes -->
  <div class="absolute top-0 right-0 w-[55%] h-full bg-storehouse-50/50 rounded-bl-[120px] -z-0"></div>
  <div class="absolute -top-24 -right-24 w-80 h-80 bg-storehouse-200/25 rounded-full blur-3xl"></div>
  <div class="absolute bottom-16 left-[15%] w-64 h-64 bg-storehouse-100/15 rounded-full blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left column: Headline and intro -->
      <div class="lg:col-span-7">
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">
          Our Story
        </p>

        <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-6xl xl:text-[4.5rem] text-text-deep leading-[0.95] reveal reveal-delay-1">
          A real estate agent<br />
          named Bob changed<br />
          <span class="text-storehouse-600">my life.</span>
        </h1>

        <p class="mt-8 text-lg sm:text-xl text-text-body leading-relaxed max-w-xl reveal reveal-delay-2">
          This is the true story behind Storehouse &mdash; and why I believe
          margin matters more than maximization.
        </p>
      </div>

      <!-- Right column: Decorative pull quote -->
      <div class="lg:col-span-5 reveal reveal-delay-3">
        <div class="relative">
          <div class="absolute inset-4 bg-storehouse-400/10 rounded-3xl blur-2xl"></div>
          <div class="relative bg-warm-white rounded-2xl p-8 sm:p-10 border border-storehouse-100/60">
            <span class="block font-quote text-6xl text-storehouse-400/40 leading-none select-none" aria-hidden="true">&ldquo;</span>
            <p class="font-quote text-2xl sm:text-3xl text-text-deep leading-snug italic -mt-4">
              I want you to see the value of leaving yourself some margin.
            </p>
            <div class="mt-6 flex items-center gap-3">
              <div class="w-10 h-px bg-storehouse-300"></div>
              <p class="text-sm text-text-muted font-medium tracking-wide uppercase">Bob, 1998</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
