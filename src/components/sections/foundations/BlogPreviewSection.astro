---
import { getCollection } from 'astro:content';
import BlogCard from '../../BlogCard.astro';

const allBlogPosts = await getCollection('blog');
const recentPosts = allBlogPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

{recentPosts.length > 0 && (
  <section class="py-20 md:py-28 bg-warm-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase">
          From the blog
        </p>
        <h2 class="mt-4 font-display text-2xl sm:text-3xl text-text-deep">
          More from the blog
        </h2>
        <p class="mt-2 text-text-muted">
          Practical articles on biblical stewardship, margin, and money.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 reveal reveal-delay-1">
        {recentPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            publishDate={post.data.publishDate}
            category={post.data.category}
            featured={post.data.featured}
          />
        ))}
      </div>

      <div class="mt-8 text-center reveal reveal-delay-2">
        <a
          href="/blog"
          class="inline-flex items-center text-sm font-medium text-storehouse-600 hover:text-storehouse-700 transition-colors duration-150"
        >
          View all posts &rarr;
        </a>
      </div>
    </div>
  </section>
)}
