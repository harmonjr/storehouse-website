---
import Button from '../Button.astro';
import { Image } from 'astro:assets';
import dashboardImage from '../../assets/images/dashboard-screenshot.png';
---

<section class="relative min-h-screen pt-20 pb-12 flex items-center overflow-hidden bg-warm-cream">
  <!-- Soft organic background shapes -->
  <div class="absolute top-0 right-0 w-[60%] h-full bg-storehouse-50/60 rounded-bl-[120px] -z-0"></div>
  <div class="absolute -top-32 -right-32 w-96 h-96 bg-storehouse-200/30 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-[20%] w-80 h-80 bg-storehouse-100/20 rounded-full blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Left column: Copy -->
      <div class="lg:col-span-6 xl:col-span-5">
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">
          Personal finance, re-ordered
        </p>

        <h1 class="mt-6 font-display text-5xl sm:text-6xl lg:text-[4.25rem] text-text-deep leading-[0.95] reveal reveal-delay-1">
          Store today.<br />
          <span class="text-storehouse-600">Thrive</span> tomorrow.
        </h1>

        <p class="mt-8 text-lg sm:text-xl text-text-body leading-relaxed max-w-lg reveal reveal-delay-2">
          One number tells you what's truly safe to spend &mdash; after giving, saving, and bills are already handled. No guilt. No guessing.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 reveal reveal-delay-3">
          <Button href="/waitlist" variant="primary" size="lg">
            Join the Waitlist
          </Button>
          <Button href="#how-it-works" variant="ghost" size="lg">
            See how it works &darr;
          </Button>
        </div>

        <p class="mt-5 text-sm text-text-muted reveal reveal-delay-4">
          Launching soon. Free to start. No credit card.
        </p>
      </div>

      <!-- Right column: Dashboard -->
      <div class="lg:col-span-6 xl:col-span-7 flex justify-center lg:justify-end reveal reveal-delay-3">
        <div class="relative max-w-sm sm:max-w-md">
          <!-- Glow behind screenshot -->
          <div class="absolute inset-4 bg-storehouse-400/15 rounded-3xl blur-2xl"></div>

          <div class="relative rounded-2xl shadow-[0_32px_64px_-16px_rgba(22,101,52,0.2)] overflow-hidden border border-storehouse-200/40">
            <Image
              src={dashboardImage}
              alt="Storehouse dashboard showing $847 Safe to Spend with giving and saving complete"
              class="w-full h-auto"
              loading="eager"
            />
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 sm:-left-8 bg-warm-white rounded-2xl px-5 py-3 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.1)] border border-storehouse-100">
            <p class="text-xs text-text-muted font-medium">Safe to Spend</p>
            <p class="font-display text-2xl text-storehouse-700">$847.23</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
