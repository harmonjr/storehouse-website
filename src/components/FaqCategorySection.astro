---
import type { FaqCategory } from '../lib/faq-data';

interface Props {
  category: FaqCategory;
}

const { category } = Astro.props;
---

<div id={category.id} class="scroll-mt-20 reveal">
  <h2 class="font-display text-2xl text-text-deep mb-6 pb-2 border-b border-text-faint/20">
    {category.label}
  </h2>
  <div class="space-y-4">
    {category.items.map((item) => (
      <details class="faq-item group">
        <summary class="faq-summary">
          <span>{item.question}</span>
          <svg class="faq-chevron" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>{item.answer}</p>
          {item.listItems && (
            <ul>
              {item.listItems.map((li) => (
                <li>{li}</li>
              ))}
            </ul>
          )}
        </div>
      </details>
    ))}
  </div>
</div>

<style>
  .faq-item {
    border: 1px solid var(--color-text-faint, #A8A29E);
    border-color: color-mix(in srgb, var(--color-text-faint, #A8A29E) 25%, transparent);
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: var(--color-warm-white, #FAFAF9);
  }

  .faq-item[open] {
    border-color: var(--color-storehouse-200, #bbf7d0);
    background-color: var(--color-warm-cream, #FAF8F5);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem;
    cursor: pointer;
    text-align: left;
    font-weight: 500;
    color: var(--color-text-deep, #1C1917);
    list-style: none;
    transition: background-color 0.15s;
  }

  .faq-summary:hover {
    background-color: var(--color-warm-cream, #FAF8F5);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-text-faint, #A8A29E);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--color-storehouse-500, #22c55e);
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem 1.25rem;
    color: var(--color-text-body, #44403C);
    line-height: 1.625;
  }

  .faq-answer p {
    margin-bottom: 0.75rem;
  }

  .faq-answer p:last-child {
    margin-bottom: 0;
  }

  .faq-answer ul {
    list-style-type: disc;
    list-style-position: inside;
    margin-left: 0.25rem;
    margin-top: 0.5rem;
  }

  .faq-answer ul li {
    margin-bottom: 0.25rem;
    color: var(--color-text-body, #44403C);
  }
</style>
