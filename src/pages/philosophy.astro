---
import PageLayout from '../layouts/PageLayout.astro'
import Header from '../components/Header.astro'
import MobileNav from '../components/MobileNav.astro'
import Footer from '../components/Footer.astro'
import HeroSection from '../components/sections/philosophy/HeroSection.astro'
import OptimizationSection from '../components/sections/philosophy/OptimizationSection.astro'
import MarginSection from '../components/sections/philosophy/MarginSection.astro'
import GiveFirstSection from '../components/sections/philosophy/GiveFirstSection.astro'
import JosephSection from '../components/sections/philosophy/JosephSection.astro'
import WorshipSection from '../components/sections/philosophy/WorshipSection.astro'
import MetaphorSection from '../components/sections/philosophy/MetaphorSection.astro'
import NotProsperitySection from '../components/sections/philosophy/NotProsperitySection.astro'
import InvitationSection from '../components/sections/philosophy/InvitationSection.astro'

const description = "Storehouse is built on a different way of thinking about money. Give first. Save second. Build margin. Here's the philosophy behind the product."
---

<PageLayout title="Philosophy | Storehouse" description={description}>
  <Header slot="header" transparent />
  <MobileNav />

  <!-- Section 1: Hero — Left-aligned editorial -->
  <HeroSection />

  <!-- Section 2: The Problem with Optimization (dark) -->
  <OptimizationSection />

  <!-- Section 3: What is Margin? -->
  <MarginSection />

  <!-- Section 4: Give-First Principle -->
  <GiveFirstSection />

  <!-- Section 5: The Joseph Principle (dark) -->
  <JosephSection />

  <!-- Section 6: Margin as Worship -->
  <WorshipSection />

  <!-- Section 7: The Storehouse Metaphor -->
  <MetaphorSection />

  <!-- Section 8: Not Prosperity Gospel (dark) -->
  <NotProsperitySection />

  <!-- Section 9: The Invitation -->
  <InvitationSection />

  <Footer slot="footer" />
</PageLayout>

<script>
  // Scroll-triggered reveal animations
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => {
      observer.observe(el);
    });
  } else {
    document.querySelectorAll('.reveal').forEach((el) => {
      el.classList.add('visible');
    });
  }
</script>
