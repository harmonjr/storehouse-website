---
import PageLayout from '../layouts/PageLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import MobileNav from '../components/MobileNav.astro'
import Button from '../components/Button.astro'
import WaitlistForm from '../components/WaitlistForm.astro'

const features = [
  'Safe to Spend dashboard',
  'Give, Save, Bills priority tracking',
  'Margin reserve monitoring',
  'Subscription tracker',
  'Unlimited account tracking',
  'Weekly balance updates through manual import',
  'Joseph Principle margin building',
  'Giving tracker with annual totals',
]

const faqs = [
  { question: 'What is Safe to Spend?', answer: "It's the money you can spend freely without worrying about bills, savings goals, or upcoming expenses. One number, total clarity." },
  { question: 'How is Storehouse different from other budgeting apps?', answer: "Most apps track what you've already spent. Storehouse shows what's truly available after your priorities are handled." },
  { question: 'Is there a free trial?', answer: 'Yes! You get 14 days free to explore everything. No credit card required to start.' },
  { question: 'Can I cancel anytime?', answer: 'Absolutely. Cancel with one click, no questions asked. Your data remains yours.' },
]

const description = "Simple, transparent pricing for Storehouse. Lock in founding member rates and get everything you need for financial peace."
---

<PageLayout title="Pricing | Storehouse" description={description}>
  <Header slot="header" />
  <MobileNav />

  <section class="relative pt-32 pb-16 md:pt-40 md:pb-20 bg-warm-cream overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-storehouse-200/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-[20%] w-80 h-80 bg-storehouse-100/15 rounded-full blur-3xl"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase reveal">Pricing</p>
        <h1 class="mt-4 font-display text-4xl sm:text-5xl text-text-deep leading-[1.05] reveal reveal-delay-1">Simple pricing. No surprises.</h1>
        <p class="mt-6 text-lg sm:text-xl text-text-body reveal reveal-delay-2">Just like your Safe to Spend number — clear, honest, and easy to understand.</p>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-warm-white">
    <div class="mx-auto max-w-lg px-4 sm:px-6 lg:px-8 reveal">
      <div class="relative bg-warm-cream border border-storehouse-200/60 rounded-2xl p-8 shadow-sm">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-flex items-center gap-1.5 bg-gold-500 text-warm-white text-sm font-semibold px-4 py-1.5 rounded-full shadow-xs">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Founding Member
          </span>
        </div>
        <p class="mt-4 text-center text-text-muted text-sm">Limited time offer for early supporters</p>
        <div class="mt-6 text-center">
          <div class="flex items-baseline justify-center gap-1">
            <span class="font-display text-5xl text-text-deep">$4.99</span>
            <span class="text-text-muted">/month</span>
          </div>
          <p class="mt-2 text-storehouse-600 font-medium">or $49/year <span class="text-text-muted">(save 2 months)</span></p>
        </div>
        <div class="my-8 border-t border-storehouse-100"></div>
        <div class="space-y-1">
          <p class="text-sm font-semibold text-text-deep mb-4">Everything you need for financial peace:</p>
          <ul class="space-y-3">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-storehouse-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-body">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="mt-8">
          <Button href="/waitlist" variant="primary" size="lg" class="w-full">Start Free Trial</Button>
          <p class="mt-3 text-center text-sm text-text-muted">14 days free. Cancel anytime.</p>
        </div>
        <div class="mt-6 p-4 bg-storehouse-50 rounded-xl border border-storehouse-100">
          <p class="text-sm text-text-body text-center">
            <span class="font-medium text-text-deep">Founding member pricing locked in for life</span><br />— even when prices increase.
          </p>
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-text-muted">After founding period: $7.99/month or $79/year</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-warm-cream">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="font-display text-2xl text-text-deep">Built for families and individuals who want financial peace.</p>
      <p class="mt-4 text-text-muted">Stop stressing about money. Start living with margin.</p>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-warm-white">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <p class="text-storehouse-600 font-semibold text-sm tracking-widest uppercase text-center reveal">Questions</p>
      <h2 class="mt-4 font-display text-2xl sm:text-3xl text-text-deep text-center reveal reveal-delay-1">Common questions</h2>
      <div class="mt-12 space-y-6 reveal reveal-delay-2">
        {faqs.map((faq) => (
          <div class="border-b border-text-faint/20 pb-6">
            <h3 class="font-semibold text-text-deep">{faq.question}</h3>
            <p class="mt-2 text-text-body">{faq.answer}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center reveal">
        <a href="/faq" class="inline-flex items-center text-storehouse-600 hover:text-storehouse-700 font-medium transition-colors duration-150">
          See all FAQs
          <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-36 bg-warm-stone grain-overlay">
    <div class="relative z-10 mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-warm-white leading-[1.05] reveal">Ready to find peace with your money?</h2>
      <p class="mt-6 text-lg text-warm-white/70 leading-relaxed reveal reveal-delay-1">Join the waitlist and be the first to trade budget anxiety for a single, clear number.</p>
      <div class="mt-12 rounded-2xl bg-warm-white/[0.07] backdrop-blur-sm border border-warm-white/10 p-6 sm:p-8 reveal reveal-delay-2">
        <WaitlistForm class="[&_input]:bg-warm-white [&_input]:border-warm-white/20 [&_select]:bg-warm-white [&_select]:border-warm-white/20 [&_button]:bg-storehouse-500 [&_button]:text-warm-white [&_button:hover]:bg-storehouse-600 [&_p]:text-warm-white/60" />
      </div>
      <p class="mt-8 text-sm text-warm-white/40 reveal reveal-delay-3">14 days free. No credit card required to start. Cancel anytime.</p>
    </div>
  </section>

  <Footer slot="footer" />
</PageLayout>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } }); },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => { observer.observe(el); });
  } else {
    document.querySelectorAll('.reveal').forEach((el) => { el.classList.add('visible'); });
  }
</script>
